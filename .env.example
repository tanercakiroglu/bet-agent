# Copy to .env and fill in your Odds-API.io key:
#   cp .env.example .env   (Linux/macOS)
#   copy .env.example .env (Windows)

# Required for Odds-API.io odds collection (ilk yari KG+taraf)
ODDS_API_IO_KEY=

# Optional overrides (defaults work for docker compose)
ODDS_API_IO_BASE_URL=https://api.odds-api.io/v3
ODDS_API_IO_BOOKMAKERS=Bet365,SBOBET
ODDS_API_IO_REQUEST_BUDGET=100
ODDS_API_IO_EVENT_LIMIT=900
ODDS_API_IO_MAX_ODDS_REQUESTS_PER_RUN=95
ODDS_API_IO_ODDS_FETCH_MODE=pending_only
ODDS_API_IO_SKIP_ODDS_WITHIN_HOURS=1
ODDS_API_IO_MIN_MINUTES_BETWEEN_RUNS=50
ODDS_API_IO_COLLECTION_ENABLED=true
ODDS_API_IO_COLLECTION_INTERVAL=1h

# Sharp prediction filters (dashboard can also change these)
PREDICTION_MIN_SAMPLES=8
PREDICTION_MIN_EDGE=0.08
PREDICTION_MIN_CONFIDENCE=0.45

# Nesine HT/FT — public bulten, no key needed
NESINE_ENABLED=true
NESINE_SCORE_JOB_ENABLED=true
